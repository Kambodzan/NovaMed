# ===== NovaMed — konfiguracja wdrozenia VPS =====
# Skopiuj do  deploy/.env  i wypelnij. NIE commituj .env (jest w .gitignore).
#   cp deploy/.env.prod.example deploy/.env

# --- Domena (musi wskazywac rekordem A na IP tego VPS-a) ---
DOMAIN=novamed.twojadomena.pl

# --- Tryb pracy ---
# Zostaw puste/false na produkcji (ES256-only auth, twarde guardy, brak dev-tokenu).
# true = tryb demonstracyjny: login bez hasla (/auth/dev-token), HS256, luzny CORS,
# kod OTP zwracany w odpowiedzi. Wygodne do dema, ale NIE zostawiaj publicznie na stale.
# (OTP i tak dziala bez tego, bo SMS_PROVIDER=mock zwraca kod — patrz nizej.)
# DEV_MODE=false

# Kafle szybkiego logowania (konta testowe) na ekranie logowania. Domyslnie ukryte
# w buildzie produkcyjnym. true = pokaz je (build prezentacyjny, np. na obrone).
# To realne konta Supabase (haslo NovaMed.Test1), wiec to tylko wygoda klikania.
# DEMO_LOGINS=true

# --- PostgreSQL (kontener db; haslo wygeneruj losowo) ---
POSTGRES_USER=novamed
POSTGRES_PASSWORD=ZMIEN_mocne_haslo_bazy
POSTGRES_DB=novamed

# --- Supabase Auth (z dashboardu projektu: Settings -> API) ---
SUPABASE_URL=https://twojprojekt.supabase.co
# Settings -> API -> JWT Settings -> JWT Secret  (do weryfikacji podpisu po stronie backendu)
SUPABASE_JWT_SECRET=
# Settings -> API -> Project API keys -> service_role  (uzywany TYLKO przez init/provision-users)
SUPABASE_SERVICE_ROLE_KEY=
# Settings -> API -> Project API keys -> anon public  (PUBLICZNY — zapiekany w buildzie frontu)
SUPABASE_ANON_KEY=

# --- Szyfrowanie danych medycznych at-rest (AES-256-GCM) + blind index PESEL ---
# Wygeneruj OBA (32 bajty base64).  Linux/Mac:  bash deploy/gen-keys.sh
#   lub:  python3 -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
# UWAGA: po pierwszym uruchomieniu NIE zmieniaj — inaczej istniejacych danych nie odszyfrujesz.
DATA_ENCRYPTION_KEY=
DATA_INDEX_KEY=

# --- Wydajnosc backendu (workery uvicorn per kontener; ~ liczba rdzeni) ---
WEB_CONCURRENCY=3

# --- Realne SMS (Twilio) — OPCJONALNE, do dema ---------------------------------
# Domyslnie mock (nic nie wychodzi, kod OTP widac na ekranie). Realna dostawa:
# SMS_PROVIDER=twilio + dane z konsoli Twilio. UWAGA trial: SMS dociera TYLKO na
# zweryfikowany numer, dlatego SMS_REDIRECT_TO kieruje WSZYSTKIE SMS na ten jeden
# numer (wymaga DEV_MODE=true). Oryginalny adresat jest dopisany w tresci.
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_FROM=+1xxxxxxxxxx              # numer nadawcy z Twilio (E.164)
# SMS_REDIRECT_TO=+48xxxxxxxxx          # Twoj zweryfikowany numer (trial)

# --- Realne e-maile (SMTP) — OPCJONALNE, do dema -------------------------------
# Domyslnie mock. Realna dostawa: EMAIL_PROVIDER=smtp + dane serwera (np. Gmail z
# haslem aplikacji, SendGrid, wlasny SMTP). EMAIL_COPY_TO = kopia KAZDEGO maila na
# staly adres OPROCZ adresata (user dostaje swoj, Ty druga kopie).
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=twoje@gmail.com
# SMTP_PASSWORD=haslo_aplikacji_gmail
# SMTP_FROM=NovaMed <twoje@gmail.com>
# EMAIL_COPY_TO=kopia@twojadomena.pl
