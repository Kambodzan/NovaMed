# ===== NovaMed — konfiguracja wdrozenia VPS =====
# Skopiuj do  deploy/.env  i wypelnij. NIE commituj .env (jest w .gitignore).
#   cp deploy/.env.prod.example deploy/.env

# --- Domena (musi wskazywac rekordem A na IP tego VPS-a) ---
DOMAIN=novamed.twojadomena.pl

# --- PostgreSQL (kontener db; haslo wygeneruj losowo) ---
POSTGRES_USER=novamed
POSTGRES_PASSWORD=ZMIEN_mocne_haslo_bazy
POSTGRES_DB=novamed

# --- Supabase Auth (z dashboardu projektu: Settings -> API) ---
SUPABASE_URL=https://twojprojekt.supabase.co
# Settings -> API -> JWT Settings -> JWT Secret  (do weryfikacji podpisu po stronie backendu)
SUPABASE_JWT_SECRET=
# Settings -> API -> Project API keys -> service_role  (uzywany TYLKO przez init/provision-users)
SUPABASE_SERVICE_ROLE_KEY=
# Settings -> API -> Project API keys -> anon public  (PUBLICZNY — zapiekany w buildzie frontu)
SUPABASE_ANON_KEY=

# --- Szyfrowanie danych medycznych at-rest (AES-256-GCM) + blind index PESEL ---
# Wygeneruj OBA (32 bajty base64).  Linux/Mac:  bash deploy/gen-keys.sh
#   lub:  python3 -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
# UWAGA: po pierwszym uruchomieniu NIE zmieniaj — inaczej istniejacych danych nie odszyfrujesz.
DATA_ENCRYPTION_KEY=
DATA_INDEX_KEY=

# --- Wydajnosc backendu (workery uvicorn per kontener; ~ liczba rdzeni) ---
WEB_CONCURRENCY=3
