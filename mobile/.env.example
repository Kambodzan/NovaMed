# Skopiuj do .env.local i uzupełnij. Bez Supabase aplikacja działa w trybie dev-token.

# Uwierzytelnianie przez Supabase (jak w portalu webowym). Klucz anon jest publiczny.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Adres backendu NovaMed API (np. http://192.168.1.10:8000). Pozostaw puste, aby celować
# w host Metro na :8000 po HTTPS. Na fizycznym urządzeniu użyj HTTP (cert self-signed).
EXPO_PUBLIC_API_URL=
