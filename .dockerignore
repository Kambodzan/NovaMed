# Kontekst budowania obrazow z kontekstem = root repo (init, mock, frontend).
# Wyklucza ciezkie/niepotrzebne katalogi i SEKRETY; zostawia zrodla potrzebne obrazom
# (backend/, scripts/, data/, mocks/, frontend/ + deploy/nginx.frontend.conf).
.git
.gitignore
**/__pycache__
**/*.pyc
**/.venv
**/venv
**/node_modules
**/dist
**/.env
**/.env.*
!**/.env.*.example
**/.pytest_cache
htmlcov
**/htmlcov
**/*.log
docs
mockupy-ui
mobile
certs
backups
*.docx
*.pdf
*.bundle
