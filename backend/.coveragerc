# Konfiguracja pomiaru pokrycia (NFR M10). Liczymy tylko kod aplikacji (app/);
# z licznika wyłączone: testy, migracje Alembica i kod nieosiągalny w środowisku
# deweloperskim (gałąź bez Ariala — fallback fontu PDF, blok __main__).
[run]
source = app
omit =
    app/main.py
    */__init__.py

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
    \.\.\.
show_missing = True
