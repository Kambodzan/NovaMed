# Skopiuj do .env i uzupełnij realnymi wartościami (NIGDY nie commituj .env).
# Ten plik zawiera WYŁĄCZNIE placeholdery — żadnych prawdziwych sekretów.
DATABASE_URL=postgresql+psycopg://novamed:novamed@localhost:5432/novamed_dev

# Supabase Auth (dashboard projektu: Settings -> API).
# Sekrety bierz z dashboardu Supabase i trzymaj tylko w .env (gitignore).
SUPABASE_URL=https://<twoj-projekt>.supabase.co
SUPABASE_JWT_SECRET=<jwt-secret-z-dashboardu>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-z-dashboardu>

# Tryb deweloperski (login bez Supabase, /auth/dev-token, fallback HS256).
# W PRODUKCJI ustaw DEV_MODE=false (albo pomiń) — wtedy dev-token i HS256 są wyłączone.
DEV_MODE=true

# Publiczny URL frontendu — trafia do linków w SMS/e-mail (potwierdzenie wizyty, teleporada).
# DEV: localhost. PRODUKCJA (DEV_MODE=false): WYMAGANE — realna domena (guard odrzuca localhost/LAN).
PUBLIC_BASE_URL=https://app.twojadomena.pl

# Szyfrowanie danych medycznych at-rest (AES-256-GCM) + blind index PESEL (HMAC).
# DEV: pozostaw puste (klucz pochodzi deterministycznie z JWT-secret). PRODUKCJA
# (DEV_MODE=false): WYMAGANE — wygeneruj 32-bajtowe klucze:
#   python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
DATA_ENCRYPTION_KEY=
DATA_INDEX_KEY=

# SMS: domyślnie mock-serwis (mocks/sms na :8106). Realna dostawa = Twilio:
# ustaw SMS_PROVIDER=twilio i poniższe sekrety z konsoli Twilio (konto trial
# wystarcza — SMS tylko na zweryfikowane numery). Bez nich zostaje mock.
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=<sid-z-twilio>
TWILIO_AUTH_TOKEN=<auth-token-z-twilio>
TWILIO_FROM=+1XXXXXXXXXX
