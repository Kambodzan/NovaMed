# Skopiuj do .env i uzupełnij realnymi wartościami (NIGDY nie commituj .env).
# Ten plik zawiera WYŁĄCZNIE placeholdery — żadnych prawdziwych sekretów.
DATABASE_URL=***REMOVED***_dev

# Supabase Auth (dashboard projektu: Settings -> API).
# Sekrety bierz z dashboardu Supabase i trzymaj tylko w .env (gitignore).
SUPABASE_URL=https://<twoj-projekt>.supabase.co
SUPABASE_JWT_SECRET=<jwt-secret-z-dashboardu>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-z-dashboardu>

# Tryb deweloperski (login bez Supabase, /auth/dev-token, fallback HS256).
# W PRODUKCJI ustaw DEV_MODE=false (albo pomiń) — wtedy dev-token i HS256 są wyłączone.
DEV_MODE=true
